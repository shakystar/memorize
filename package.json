{
  "name": "@shakystar/memorize",
  "version": "2.3.1",
  "license": "AGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "author": "shakystar",
  "description": "Shared, persistent memory for AI coding agents — Claude Code & Codex share one local-first, event-sourced project brain that survives sessions and syncs across machines.",
  "homepage": "https://github.com/shakystar/memorize#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shakystar/memorize.git"
  },
  "bugs": {
    "url": "https://github.com/shakystar/memorize/issues"
  },
  "keywords": [
    "memorize",
    "ai-agents",
    "agent-memory",
    "ai-memory",
    "llm-memory",
    "claude-code",
    "claude",
    "codex",
    "context-engineering",
    "event-sourcing",
    "local-first",
    "shared-memory",
    "cli",
    "collaboration"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "AGENT_GUIDE.md",
    "docs/ARCHITECTURE.md",
    "guides/AI_SETUP.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "memorize": "dist/cli/index.js"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && node scripts/validate/write-cli-shebang.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/integration/cli-smoke.test.ts",
    "test:golden": "vitest run tests/golden",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "qa:quick": "pnpm typecheck && pnpm lint && pnpm test:unit && pnpm test:smoke",
    "qa:full": "pnpm check && pnpm test:integration && pnpm test:golden",
    "fixture:reset": "tsx scripts/fixtures/reset-fixture.ts",
    "benchmark:import": "tsx scripts/benchmarks/run-import-benchmark.ts",
    "benchmark:startup": "tsx scripts/benchmarks/run-startup-benchmark.ts",
    "benchmark:handoff": "tsx scripts/benchmarks/run-handoff-benchmark.ts",
    "benchmark:conflict": "tsx scripts/benchmarks/run-conflict-benchmark.ts",
    "benchmark:all": "pnpm benchmark:import && pnpm benchmark:startup && pnpm benchmark:handoff && pnpm benchmark:conflict",
    "dogfood:stats": "tsx scripts/dogfood-stats.ts",
    "dogfood:capture-audit": "tsx scripts/decision-capture-audit.ts",
    "dogfood:label": "tsx scripts/decision-label.ts",
    "dogfood:miss-rate": "tsx scripts/decision-miss-rate.ts",
    "pack:check": "tsx scripts/validate/package-dry-run.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "cross-spawn": "^7.0.6",
    "ps-list": "^9.0.0",
    "which": "^7.0.0",
    "write-file-atomic": "^8.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.6.0",
    "@types/which": "^3.0.4",
    "@types/write-file-atomic": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
