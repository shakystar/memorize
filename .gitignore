# OSX
.DS_Store

# OMX runtime/state
.omx/

# OMC runtime/state
.omc/

# Local working docs (plans, specs, superpowers, ...) stay untracked by default;
# only the explicitly whitelisted public docs below are committed.
/docs/*
!/docs/ARCHITECTURE.md
!/docs/i18n/

# Git worktrees (subagent workspaces)
/.worktrees/

# Claude Code local workflow settings
/.claude/
/CLAUDE.md

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Node / JS
node_modules/
dist/
build/
coverage/
.pnpm-store/
.npm/

# pnpm / npm pack artifacts
*.tgz

# Python
__pycache__/
.pytest_cache/
.venv/

# Env files
.env
.env.*
!.env.example

# Local project link
.memorize/
gitPAT.txt
# Added by code-review-graph
.code-review-graph/

# Local AI tool configs generated by code-review-graph install
/.mcp.json
/.opencode.json
/.gemini/
/.qoder/
/.vscode/

# Private dogfood measurement artifacts — judge labels derived from session
# transcripts (private project content); local-only, never committed (#99).
scripts/dogfood/labels/
